# Example environment variables for grid-pulse-spain

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_RAW=grid_pulse_raw
BIGQUERY_DATASET_ANALYTICS=grid_pulse_analytics
